# Core app
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=change-me-please
# Encryption key for at-rest org provider secrets (AES-256-GCM).
# REQUIRED in production. Accepts: 32-byte base64, 64-char hex, or any string
# (will be SHA-256 derived). Falls back to AUTH_SECRET in non-production only.
ADMIN_SECRETS_ENCRYPTION_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/platformaai?schema=public
POSTGRES_DB=platformaai
POSTGRES_USER=platformaai
POSTGRES_PORT=5432

# Optional Redis (Upstash REST) for distributed rate-limit / AI cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Docker local services
POSTGRES_PASSWORD=postgres
PGADMIN_PASSWORD=admin

# Dev auth bypass (enable only for local debugging)
AUTH_BYPASS=0
AUTH_BYPASS_EMAIL=dev@platforma.local
AUTH_BYPASS_ROLE=ADMIN
AUTH_BYPASS_BALANCE=1000

# AI providers
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=PlatformaAI
OPENROUTER_MARKUP=2
DEFAULT_IMAGE_MODEL_ID=black-forest-labs/flux.2-klein-4b
IMAGE_GENERATION_ENABLED=1
IMAGE_GENERATION_STORAGE_DIR=./generated-images

# Optional OpenAI/STT
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=ru
WHISPER_USD_PER_MINUTE=0.006

# Payments / YooKassa
USD_PER_CREDIT=0.01
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=
YOOKASSA_WEBHOOK_SECRET=
BILLING_REFILL_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_LOGIN_BOT_NAME=platformaai_bot
NEXT_PUBLIC_TELEGRAM_LOGIN_BOT_NAME=platformaai_bot
NEXT_PUBLIC_TELEGRAM_AUTH_ENABLED=0
TELEGRAM_WEBHOOK_SECRET=
FEEDBACK_TELEGRAM_CHAT_IDS=

# Email (UniSender, primary)
UNISENDER_API_KEY=
UNISENDER_SENDER_EMAIL=
UNISENDER_SENDER_NAME=PlatformaAI

# Email (SMTP fallback, optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PlatformaAI

# SSO / OIDC
SSO_ISSUER=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_NAME=SSO
NEXT_PUBLIC_SSO_ENABLED=0

# Security / internal APIs
CRON_SECRET=change-me-cron-secret

# Moderation & feature flags
MODERATION_ENABLED=0
MODERATION_BLOCKLIST=
ENABLE_CHAT_SUMMARY=1
LOG_EVENTS=0

# Audit log (optional hardening)
AUDIT_LOG_ENABLED=1
AUDIT_LOG_PURGE_INTERVAL_MS=
AUDIT_LOG_RETENTION_ENABLED=0
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_BATCH_SIZE=1000
AUDIT_LOG_RETENTION_BATCH_DELAY_MS=100
AUDIT_LOG_RETENTION_MAX_RUNTIME_MINUTES=5
AUDIT_LOG_RETENTION_DRY_RUN=0
AUDIT_LOG_METRICS_ENABLED=0
AUDIT_LOG_METRICS_ACTION_TYPES=
