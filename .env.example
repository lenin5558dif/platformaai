# PlatformaAI environment template
# Copy this file to `.env.local` and fill in the values before running the app.

# ---------------------------------------------------------------------------
# Core app URLs
# Keep these aligned. `NEXTAUTH_URL` is used by Auth.js, while the public URL is
# used in client-facing links and redirects.
# ---------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional server-side alias. If you set it, keep it equal to NEXTAUTH_URL.
APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Auth.js / NextAuth
# ---------------------------------------------------------------------------
AUTH_SECRET=replace-with-a-long-random-secret
# Optional compatibility alias. Keep it equal to AUTH_SECRET if you use it.
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://platformaai:platformaai_password@localhost:5433/platformaai?schema=public

# ---------------------------------------------------------------------------
# OpenRouter / AI
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=replace-with-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=PlatformaAI
OPENROUTER_MARKUP=1.0
USD_PER_CREDIT=0.01

# ---------------------------------------------------------------------------
# Email delivery / invites
# UNISENDER_SENDER_EMAIL is used for email delivery flows such as invites.
# ---------------------------------------------------------------------------
UNISENDER_API_KEY=replace-with-your-unisender-key
UNISENDER_SENDER_EMAIL=no-reply@example.com
UNISENDER_SENDER_NAME=PlatformaAI
AUTH_EMAIL_BLOCKLIST=
AUTH_EMAIL_SUSPICIOUS_DOMAINS=

# ---------------------------------------------------------------------------
# Billing / Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ---------------------------------------------------------------------------
# Voice transcription / Whisper
# ---------------------------------------------------------------------------
OPENAI_API_KEY=replace-with-your-openai-key
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=ru
WHISPER_USD_PER_MINUTE=0.006

# ---------------------------------------------------------------------------
# Telegram
# Use these if you enable Telegram auth or the Telegram bot.
# Keep public and server bot names in sync.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_LOGIN_BOT_NAME=
NEXT_PUBLIC_TELEGRAM_LOGIN_BOT_NAME=
NEXT_PUBLIC_TELEGRAM_AUTH_ENABLED=0

# ---------------------------------------------------------------------------
# Temporary access
# Enable only for support or staging flows.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_TEMP_ACCESS_ENABLED=0
TEMP_ACCESS_TOKEN=
TEMP_ACCESS_EMAIL=temp-access@platforma.local
TEMP_ACCESS_ROLE=ADMIN

# ---------------------------------------------------------------------------
# SSO / OIDC
# Set the full trio together.
# ---------------------------------------------------------------------------
SSO_ISSUER=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_NAME=SSO
NEXT_PUBLIC_SSO_ENABLED=1

# ---------------------------------------------------------------------------
# Dev-only access shortcuts
# Never enable AUTH_BYPASS in production.
# ---------------------------------------------------------------------------
ALLOW_USER_OPENROUTER_KEYS=0
AUTH_BYPASS=0
AUTH_BYPASS_EMAIL=dev@platforma.local
AUTH_BYPASS_ROLE=ADMIN
AUTH_BYPASS_BALANCE=1000
GLOBAL_ADMIN_EMAILS=

# ---------------------------------------------------------------------------
# Internal jobs / operations
# ---------------------------------------------------------------------------
CRON_SECRET=
BILLING_REFILL_TOKEN=

AUDIT_LOG_ENABLED=1
LOG_EVENTS=1
ENABLE_CHAT_SUMMARY=0
MODERATION_ENABLED=1
MODERATION_BLOCKLIST=

AUDIT_LOG_PURGE_INTERVAL_MS=
AUDIT_LOG_RETENTION_ENABLED=0
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_BATCH_SIZE=1000
AUDIT_LOG_RETENTION_BATCH_DELAY_MS=100
AUDIT_LOG_RETENTION_MAX_RUNTIME_MINUTES=5
AUDIT_LOG_RETENTION_DRY_RUN=0
AUDIT_LOG_METRICS_ENABLED=0
AUDIT_LOG_METRICS_ACTION_TYPES=

# ---------------------------------------------------------------------------
# Local Docker defaults
# ---------------------------------------------------------------------------
POSTGRES_DB=platformaai
POSTGRES_USER=platformaai
POSTGRES_PASSWORD=platformaai_password
POSTGRES_PORT=5433
PGADMIN_EMAIL=admin@platforma.ai
PGADMIN_PASSWORD=platformaai_password
PGADMIN_PORT=5050
